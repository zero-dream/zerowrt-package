# --------------------------------------------------

# Source
source "$ZD_LibPath/mergeRepo.sh"

# --------------------------------------------------

# MergeRepo
mergeArr=("$ZD_Owner/zerowrt-firmware")
mergeRepo 'mergeArr'

# CloneRepository
repoBranch='main'
repoUrl="https://github.com/$ZD_Owner/zerowrt-firmware.git"
outputPath="$CI_RepositoryPath/zerowrt-firmware"
git clone --depth=1 --single-branch --branch "$repoBranch" "$repoUrl" "$outputPath"

# --------------------------------------------------

exit 0
